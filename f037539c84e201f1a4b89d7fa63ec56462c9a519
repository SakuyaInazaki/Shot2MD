 int = 0):\n        self.root = tk.Tk()\n        self.root.withdraw()\n        self._setup_window(message)\n\n        if duration_ms > 0:\n            self.root.after(duration_ms, self.close)\n\n    def _setup_window(self, message: str):\n        screen_w = self.root.winfo_screenwidth()\n        screen_h = self.root.winfo_screenheight()\n\n        win_w, win_h = 320, 100\n        x = (screen_w - win_w) // 2\n        y = (screen_h - win_h) // 2\n\n        self.root.geometry(f\"{win_w}x{win_h}+{x}+{y}\")\n        self.root.configure(bg=\"#2d2d2d\")\n        self.root.overrideredirect(True)\n        self.root.attributes(\"-topmost\", True)\n        self.root.attributes(\"-alpha\", 0.95)\n        self.root.deiconify()\n\n        frame = tk.Frame(self.root, bg=\"#2d2d2d\", padx=20, pady=15)\n        frame.pack(fill=\"both\", expand=True)\n\n        self.label = tk.Label(\n            frame,\n            text=message,\n            bg=\"#2d2d2d\",\n            fg=\"white\",\n            font=(\"SF Pro Display\", 14, \"bold\")\n        )\n        self.label.pack()\n\n        self.count_label = tk.Label(\n            frame,\n            text=\"\",\n            bg=\"#2d2d2d\",\n            fg=\"#888\",\n            font=(\"\", 10)\n        )\n        self.count_label.pack(pady=(5, 0))\n\n    def update(self, message: str, count: str = \"\"):\n        self.label.config(text=message)\n        self.count_label.config(text=count)\n        self.root.update()\n\n    def close(self):\n        self.root.destroy()\n\n\n# ========== 设置窗口 ==========\nclass SettingsWindow:\n    def __init__(self, parent, config: Config, on_save):\n        self.config = config\n        self.on_save = on_save\n        self.dialog = tk.Toplevel(parent)\n        self._setup_ui()\n\n    def _setup_ui(self):\n        self.dialog.title(\"ss2md 设置\")\n        self.dialog.geometry(\"550x340\")\n        self.dialog.resizable(False, False)\n        self.dialog.transient()\n        self.dialog.grab_set()\n\n        self.dialog.update_idletasks()\n        x = (self.dialog.winfo_screenwidth() - 550) // 2\n        y = (self.dialog.winfo_screenheight() - 340) // 2\n        self.dialog.geometry(f\"550x340+{x}+{y}\")\n\n        main_frame = ttk.Frame(self.dialog, padding=20)\n        main_frame.pack(fill=\"both\", expand=True)\n\n        ttk.Label(main_frame, text=\"API 地址:\", font=(\"\", 10, \"bold\")).grid(\n            row=0, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.base_url_var = tk.StringVar(value=self.config.base_url)\n        ttk.Entry(main_frame, textvariable=self.base_url_var, width=55).grid(\n            row=1, column=0, columnspan=2, sticky=\"ew\", pady=(0, 15)\n        )\n\n        ttk.Label(main_frame, text=\"API Key:\", font=(\"\", 10, \"bold\")).grid(\n            row=2, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.api_key_var = tk.StringVar(value=self.config.api_key)\n        ttk.Entry(\n            main_frame,\n            textvariable=self.api_key_var,\n            show=\"*\",\n            width=55\n        ).grid(row=3, column=0, columnspan=2, sticky=\"ew\", pady=(0, 15))\n\n        ttk.Label(main_frame, text=\"模型:\", font=(\"\", 10, \"bold\")).grid(\n            row=4, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.model_var = tk.StringVar(value=self.config.model_name)\n        model_combo = ttk.Combobox(\n            main_frame,\n            textvariable=self.model_var,\n            values=[\n                \"gemini-2.5-pro\",\n                \"gemini-2.0-flash\",\n                \"gpt-4o\",\n                \"gpt-4o-mini\",\n                \"claude-3-5-sonnet\",\n                \"claude-3-5-haiku\",\n            ],\n            width=52,\n            state=\"readonly\"\n        )\n        model_combo.grid(row=5, column=0, columnspan=2, sticky=\"ew\", pady=(0, 20))\n\n        hint_text = (\n            \"API 地址示例:\\n\"\n            \"  OpenAI 兼容: https://runapi.co/v1\\n\"\n            \"  Claude 兼容: https://runapi.co/v1/messages\\n\"\n            \"  Gemini 兼容: https://runapi.co/v1beta/models\"\n        )\n        ttk.Label(\n            main_frame,\n            text=hint_text,\n            font=(\"\", 9),\n            foreground=\"gray\",\n            justify=\"left\"\n        ).grid(row=6, column=0, columnspan=2, sticky=\"w\", pady=(0, 15))\n\n        btn_frame = ttk.Frame(main_frame)\n        btn_frame.grid(row=7, column=0, columnspan=2, sticky=\"e\")\n\n        ttk.Button(btn_frame, text=\"取消\", command=self.dialog.destroy).pack(\n            side=\"right\", padx=(10, 0)\n        )\n        ttk.Button(btn_frame, text=\"保存\", command=self._save).pack(side=\"right\")\n\n    def _save(self):\n        api_key = self.api_key_var.get().strip()\n        base_url = self.base_url_var.get().strip()\n        model = self.model_var.get().strip()\n\n        if not api_key:\n            messagebox.showwarning(\"提示\", \"请输入 API Key\")\n            return\n        if not base_url:\n            messagebox.showwarning(\"提示\", \"请输入 API 地址\")\n            return\n\n        self.config.save(api_key, base_url, model)\n        self.on_save()\n        self.dialog.destroy()\n\n\n# ========== 多图截取器 ==========\nclass MultiCapture:\n    \"\"\"连续截取多张图片\"\"\"\n\n    def __init__(self, app, on_complete):\n        self.app = app\n        self.on_complete = on_complete\n        self.images = []\n        self.count = 0\n\n    def start(self):\n        self.images = []\n        self.count = 0\n        self._next_capture()\n\n    def _next_capture(self):\n        self.count += 1\n        hint = f\"第 {self.count} 张区域选择\"\n        if self.count > 1:\n            hint += f\"\\n按 Enter 添加下一张 | 按 Escape 完成\"\n\n        was_hidden = self.app.root.state() == \"normal\"\n        if was_hidden:\n            self.app.root.withdraw()\n\n        def callback(rect):\n            if was_hidden:\n                self.app.root.deiconify()\n\n            if rect is None:\n                # Escape 被按下\n                if self.count == 1:\n                    # 没截到任何图\n                    return\n                else:\n                    # 完成\n                    self._finish()\n            else:\n                # 截取成功\n                x1, y1, x2, y2 = rect\n                try:\n                    screenshot = PIL.ImageGrab.grab(bbox=(x1, y1, x2, y2))\n                    tmp_path = APP_DIR / f\"capture_{len(self.images)}.png\"\n                    screenshot.save(tmp_path, \"PNG\")\n                    self.images.append(tmp_path)\n\n                    # 继续下一张\n                    self.app.root.after(100, self._next_capture)\n                except Exception as e:\n                    self.app._show_error(f\"截图失败: {e}\")\n\n        self.app.root.after(200, lambda: ScreenSelector(callback, hint))\n\n    def _finish(self):\n        if self.images:\n            self.on_complete(self.images)\n\n\n# ========== 主窗口 ==========\nclass SS2MDApp:\n    def __init__(self):\n        self.config = Config()\n        self.root = tk.Tk()\n        self.root.title(\"ss2md\")\n        self.root.geometry(\"320x240\")\n        self.root.resizable(False, False)\n        self._setup_ui()\n\n        import keyboard\n        # 修改为 Cmd+Option+Shift+4\n        keyboard.add_hotkey(\"cmd+option+shift+4\", self.start_multi_capture)\n        keyboard.add_hotkey(\"ctrl+option+shift+4\", self.start_multi_capture)\n\n        self.root.protocol(\"WM_DELETE_WINDOW\", self._on_close)\n\n    def _setup_ui(self):\n        main_frame = ttk.Frame(self.root, padding=20)\n        main_frame.pack(fill=\"both\", expand=True)\n\n        ttk.Label(\n            main_frame,\n            text=\"ss2md\",\n            font=(\"SF Pro Display\", 20, \"bold\")\n        ).pack(pady=(10, 5))\n\n        ttk.Label(\n            main_frame,\n            text=\"截图 → OCR → 剪贴板\",\n            font=(\"\", 10),\n            foreground=\"gray\"\n        ).pack(pady=(0, 15))\n\n        self.status_var = tk.StringVar(value=\"就绪\")\n        if self.config.api_key:\n            self.status_var.set(f\"✓ 已配置: {self.config.model_name}\")\n        else:\n            self.status_var.set(\"请先配置 API\")\n\n        ttk.Label(\n            main_frame,\n            textvariable=self.status_var,\n            font=(\"\", 11)\n        ).pack(pady=(0, 10))\n\n        usage_text = (\n            \"📸 Cmd+Option+Shift+4 截图\\n\"\n            \"   ↓\\n\"\n            \"截完按 Enter 继续截下一张\\n\"\n            \"截完按 Escape 开始识别\"\n        )\n        ttk.Label(\n            main_frame,\n            text=usage_text,\n            font=(\"\", 9),\n            foreground=\"#666\",\n            justify=\"center\"\n        ).pack(pady=(0, 15))\n\n        ttk.Button(\n            main_frame,\n            text=\"⚙️ 设置\",\n            command=self._open_settings\n        ).pack(pady=(0, 8))\n\n        ttk.Button(\n            main_frame,\n            text=\"📷 开始截图\",\n            command=self.start_multi_capture\n        ).pack()\n\n    def _open_settings(self):\n        SettingsWindow(self.root, self.config, self._on_config_save)\n\n    def _on_config_save(self):\n        self.status_var.set(f\"✓ 已配置: {self.config.model_name}\")\n\n    def _on_close(self):\n        import keyboard\n        keyboard.remove_all_hotkeys()\n        self.root.destroy()\n        sys.exit(0)\n\n    def start_multi_capture(self):\n        \"\"\"开始多图截取流程\"\"\"\n        capture = MultiCapture(self, self._process_images)\n        capture.start()\n\n    def _process_images(self, image_paths: list):\n        if not self.config.api_key:\n            self._show_error(\"请先在设置中配置 API\")\n            return\n\n        if not image_paths:\n            return\n\n        status = StatusOverlay(f\"🔄 识别中...\\n(共 {len(image_paths)} 张)\")\n        status.root.update()\n\n        def do_ocr():\n            try:\n                engine = OCREngine(\n                    self.config.api_key,\n                    self.config.base_url,\n                    self.config.model_name\n   