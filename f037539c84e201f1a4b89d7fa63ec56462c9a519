ers\n\nDo NOT:\n- Summarize or paraphrase\n- Correct any spelling or grammar errors\n- Add explanations or comments\n\nOutput format: Pure markdown with LaTeX for math. Just the transcription, nothing else.\"\"\"\n\n    def __init__(self, api_key: str, base_url: str, model: str):\n        self.client = OpenAI(api_key=api_key, base_url=base_url)\n        self.model = model\n\n    def transcribe(self, image_path: str) -> str:\n        with open(image_path, \"rb\") as f:\n            image_data = base64.b64encode(f.read()).decode(\"utf-8\")\n\n        response = self.client.chat.completions.create(\n            model=self.model,\n            messages=[\n                {\n                    \"role\": \"user\",\n                    \"content\": [\n                        {\"type\": \"text\", \"text\": self.PROMPT},\n                        {\n                            \"type\": \"image_url\",\n                            \"image_url\": {\n                                \"url\": f\"data:image/png;base64,{image_data}\"\n                            }\n                        }\n                    ]\n                }\n            ],\n            max_tokens=8192,\n            temperature=0.1\n        )\n        return response.choices[0].message.content\n\n\n# ========== 截图选区 (类似 macOS Shift+Cmd+4) ==========\nclass ScreenSelector:\n    \"\"\"全屏半透明覆盖层，用于选择截屏区域\"\"\"\n\n    def __init__(self, callback):\n        self.callback = callback\n        self.start_x = 0\n        self.start_y = 0\n        self.rect = None\n\n        self.root = tk.Toplevel()\n        self.root.withdraw()\n        self._setup_window()\n\n    def _setup_window(self):\n        screen_width = self.root.winfo_screenwidth()\n        screen_height = self.root.winfo_screenheight()\n\n        self.root.geometry(f\"{screen_width}x{screen_height}+0+0\")\n        self.root.configure(bg=\"\")\n        self.root.overrideredirect(True)\n        self.root.attributes(\"-alpha\", 0.3)\n        self.root.attributes(\"-topmost\", True)\n        self.root.deiconify()\n\n        self.canvas = tk.Canvas(\n            self.root,\n            width=screen_width,\n            height=screen_height,\n            bg=\"gray30\",\n            highlightthickness=0,\n            cursor=\"crosshair\"\n        )\n        self.canvas.pack(fill=\"both\", expand=True)\n\n        self.canvas.bind(\"<ButtonPress-1>\", self._on_press)\n        self.canvas.bind(\"<B1-Motion>\", self._on_drag)\n        self.canvas.bind(\"<ButtonRelease-1>\", self._on_release)\n        self.root.bind(\"<Escape>\", lambda e: self._cancel())\n\n        self.canvas.focus_force()\n\n    def _on_press(self, event):\n        self.start_x = event.x\n        self.start_y = event.y\n        if self.rect:\n            self.canvas.delete(self.rect)\n        self.rect = self.canvas.create_rectangle(\n            self.start_x, self.start_y, self.start_x, self.start_y,\n            outline=\"#00BFFF\", width=2, fill=\"#00BFFF\", stipple=\"gray25\"\n        )\n\n    def _on_drag(self, event):\n        self.canvas.coords(\n            self.rect,\n            self.start_x, self.start_y, event.x, event.y\n        )\n\n    def _on_release(self, event):\n        x1 = min(self.start_x, event.x)\n        y1 = min(self.start_y, event.y)\n        x2 = max(self.start_x, event.x)\n        y2 = max(self.start_y, event.y)\n\n        self.root.destroy()\n\n        if x2 - x1 > 5 and y2 - y1 > 5:\n            self.callback((x1, y1, x2, y2))\n\n    def _cancel(self):\n        self.root.destroy()\n        self.callback(None)\n\n\n# ========== 状态浮窗 ==========\nclass StatusOverlay:\n    \"\"\"屏幕中央的半透明状态提示\"\"\"\n\n    def __init__(self, message: str, duration_ms: int = 0):\n        self.root = tk.Tk()\n        self.root.withdraw()\n        self._setup_window(message)\n\n        if duration_ms > 0:\n            self.root.after(duration_ms, self.close)\n\n    def _setup_window(self, message: str):\n        screen_w = self.root.winfo_screenwidth()\n   