            "content": "#!/usr/bin/env python3\n\"\"\"\nss2md - Screenshot to Markdown\n截屏选区 → AI OCR → 剪贴板\n支持多张截图一次性处理\n\"\"\"\n\nimport os\nimport sys\nimport base64\nimport threading\nimport configparser\nfrom pathlib import Path\n\nimport tkinter as tk\nfrom tkinter import ttk, messagebox\nimport PIL.ImageGrab\nimport pyperclip\n\ntry:\n    from openai import OpenAI\nexcept ImportError:\n    print(\"请安装 openai: pip3 install openai\")\n    sys.exit(1)\n\n# ========== macOS 全局快捷键 ==========\ndef setup_hotkey(callback):\n    \"\"\"使用 CGEventTap 注册全局快捷键 Cmd+Option+Shift+4\"\"\"\n    import Quartz as q\n\n    flags = (\n        q.kCGEventFlagMaskCommand |\n        q.kCGEventFlagMaskAlternate |\n        q.kCGEventFlagMaskShift\n    )\n\n    # keycode 21 = '4'\n    KEYCODE_4 = 21\n\n    def handle_event(proxy, event, refcon):\n        if q.CGEventGetType(event) == q.kCGEventKeyDown:\n            keycode = q.CGEventGetIntegerValueField(event, q.kCGKeyboardEventKeycode)\n            event_flags = q.CGEventGetFlags(event)\n\n            if keycode == KEYCODE_4:\n                required = q.kCGEventFlagMaskCommand | q.kCGEventFlagMaskAlternate | q.kCGEventFlagMaskShift\n                if (event_flags & required) == required:\n                    callback()\n                    return None\n        return event\n\n    tap = q.CGEventTapCreate(\n        q.kCGSessionEventTap,\n        q.kCGHeadInsertEventTap,\n        q.kCGEventTapOptionDefault,\n        q.CGEventMaskBit(q.kCGEventKeyDown),\n        handle_event,\n        None\n    )\n\n    if tap is None:\n        return None\n\n    run_loop_source = q.CFMachPortCreateRunLoopSource(None, tap, 0)\n    q.CFRunLoopAddSource(q.CFRunLoopGetCurrent(), run_loop_source, q.kCFRunLoopCommonModes)\n    q.CGEventTapEnable(tap, True)\n    return tap\n\n\n# ========== 配置路径 ==========\nAPP_DIR = Path(__file__).parent\nCONFIG_FILE = APP_DIR / \"config.ini\"\nPROMPT_FILE = APP_DIR / \"prompt.md\"\nAPP_DIR.mkdir(exist_ok=True)\n\nDEFAULT_PROMPT = \"\"\"## 角色：\n你是一位顶级的 Markdown 文档工程师和技术写作排版专家，精通文档解析、手写识别、图像分析和结构化信息抽取。\n\n## 目标：\n将用户提供的截图转换成结构清晰、语义准确的 Markdown 文档。\n\n## 输出要求：\n直接输出 Markdown 内容，包含：\n- 标题层级 (#)\n- 数学公式用 $...$ 或 $$...$$\n- 代码块标注语言\n- 表格用 GFM 语法\n- 列表用 - 或 1.\n- 保留所有原文内容和格式\n\n不要在代码块外添加任何说明。\"\"\"\n\n\n# ========== 配置管理 ==========\nclass Config:\n    def __init__(self):\n        self.api_key = \"\"\n        self.base_url = \"https://runapi.co/v1\"\n        self.model_name = \"gemini-2.5-pro\"\n        self.load()\n\n    def load(self):\n        if CONFIG_FILE.exists():\n            cfg = configparser.ConfigParser()\n            cfg.read(CONFIG_FILE)\n            self.api_key = cfg.get(\"api\", \"api_key\", fallback=\"\")\n            self.base_url = cfg.get(\"api\", \"base_url\", fallback=self.base_url)\n            self.model_name = cfg.get(\"api\", \"model\", fallback=self.model_name)\n\n    def save(self, api_key: str, base_url: str, model: str):\n        cfg = configparser.ConfigParser()\n        cfg[\"api\"] = {\n            \"api_key\": api_key,\n            \"base_url\": base_url,\n            \"model\": model\n        }\n        with open(CONFIG_FILE, \"w\") as f:\n            cfg.write(f)\n        self.api_key = api_key\n        self.base_url = base_url\n        self.model_name = model\n\n\n# ========== OCR 核心 ==========\nclass OCREngine:\n    def __init__(self, api_key: str, base_url: str, model: str):\n        self.client = OpenAI(api_key=api_key, base_url=base_url)\n        self.model = model\n\n    def _load_prompt(self) -> str:\n        if PROMPT_FILE.exists():\n            return PROMPT_FILE.read_text(encoding=\"utf-8\")\n        return DEFAULT_PROMPT\n\n    def transcribe(self, image_paths: list) -> str:\n        prompt = self._load_prompt()\n        content = [{\"type\": \"text\", \"text\": prompt}]\n\n        for path in image_paths:\n            with open(path, \"rb\") as f:\n                image_data = base64.b64encode(f.read()).decode(\"utf-8\")\n            content.append({\n                \"type\": \"image_url\",\n                \"image_url\": {\"url\": f\"data:image/png;base64,{image_data}\"}\n            })\n\n        response = self.client.chat.completions.create(\n            model=self.model,\n            messages=[{\"role\": \"user\", \"content\": content}],\n            max_tokens=16384,\n            temperature=0.1\n        )\n        return response.choices[0].message.content\n\n\n# ========== 截图选区 ==========\nclass ScreenSelector:\n    def __init__(self, callback, hint: str = \"\"):\n        self.callback = callback\n        self.hint = hint\n        self.start_x = 0\n        self.start_y = 0\n        self.rect = None\n\n        self.root = tk.Toplevel()\n        self.root.withdraw()\n        self._setup_window()\n\n    def _setup_window(self):\n        screen_width = self.root.winfo_screenwidth()\n        screen_height = self.root.winfo_screenheight()\n\n        self.root.geometry(f\"{screen_width}x{screen_height}+0+0\")\n        self.root.configure(bg=\"\")\n        self.root.overrideredirect(True)\n        self.root.attributes(\"-alpha\", 0.3)\n        self.root.attributes(\"-topmost\", True)\n        self.root.deiconify()\n\n        self.canvas = tk.Canvas(\n            self.root,\n            width=screen_width,\n            height=screen_height,\n            bg=\"gray30\",\n            highlightthickness=0,\n            cursor=\"crosshair\"\n        )\n        self.canvas.pack(fill=\"both\", expand=True)\n\n        self.hint_text = self.canvas.create_text(\n            screen_width // 2, 50,\n            text=self.hint,\n            fill=\"white\",\n            font=(\"SF Pro Display\", 16, \"bold\"),\n            anchor=\"center\"\n        )\n\n        self.canvas.bind(\"<ButtonPress-1>\", self._on_press)\n        self.canvas.bind(\"<B1-Motion>\", self._on_drag)\n        self.canvas.bind(\"<ButtonRelease-1>\", self._on_release)\n        self.root.bind(\"<Escape>\", lambda e: self._cancel())\n\n        self.canvas.focus_force()\n\n    def _on_press(self, event):\n        self.start_x = event.x\n        self.start_y = event.y\n        if self.rect:\n            self.canvas.delete(self.rect)\n        self.rect = self.canvas.create_rectangle(\n            self.start_x, self.start_y, self.start_x, self.start_y,\n            outline=\"#00BFFF\", width=2, fill=\"#00BFFF\", stipple=\"gray25\"\n        )\n\n    def _on_drag(self, event):\n        self.canvas.coords(\n            self.rect,\n            self.start_x, self.start_y, event.x, event.y\n        )\n\n    def _on_release(self, event):\n        x1 = min(self.start_x, event.x)\n        y1 = min(self.start_y, event.y)\n        x2 = max(self.start_x, event.x)\n        y2 = max(self.start_y, event.y)\n\n        self.root.destroy()\n\n        if x2 - x1 > 5 and y2 - y1 > 5:\n            self.callback((x1, y1, x2, y2))\n        else:\n            self.callback(None)\n\n    def _cancel(self):\n        self.root.destroy()\n        self.callback(None)\n\n\n# ========== 状态浮窗 ==========\nclass StatusOverlay:\n    def __init__(self, message: str, duration_ms: int = 0):\n        self.root = tk.Tk()\n        self.root.withdraw()\n        self._setup_window(message)\n\n        if duration_ms > 0:\n            self.root.after(duration_ms, self.close)\n\n    def _setup_window(self, message: str):\n        screen_w = self.root.winfo_screenwidth()\n        screen_h = self.root.winfo_screenheight()\n\n        win_w, win_h = 320, 100\n        x = (screen_w - win_w) // 2\n        y = (screen_h - win_h) // 2\n\n        self.root.geometry(f\"{win_w}x{win_h}+{x}+{y}\")\n        self.root.configure(bg=\"#2d2d2d\")\n        self.root.overrideredirect(True)\n        self.root.attributes(\"-topmost\", True)\n        self.root.attributes(\"-alpha\", 0.95)\n        self.root.deiconify()\n\n        frame = tk.Frame(self.root, bg=\"#2d2d2d\", padx=20, pady=15)\n        frame.pack(fill=\"both\", expand=True)\n\n        self.label = tk.Label(\n            frame,\n            text=message,\n            bg=\"#2d2d2d\",\n            fg=\"white\",\n            font=(\"SF Pro Display\", 14, \"bold\")\n        )\n        self.label.pack()\n\n        self.count_label = tk.Label(\n            frame,\n            text=\"\",\n            bg=\"#2d2d2d\",\n            fg=\"#888\",\n            font=(\"\", 10)\n        )\n        self.count_label.pack(pady=(5, 0))\n\n    def update(self, message: str, count: str = \"\"):\n        self.label.config(text=message)\n        self.count_label.config(text=count)\n        self.root.update()\n\n    def close(self):\n        self.root.destroy()\n\n\n# ========== 设置窗口 ==========\nclass SettingsWindow:\n    def __init__(self, parent, config: Config, on_save):\n        self.config = config\n        self.on_save = on_save\n        self.dialog = tk.Toplevel(parent)\n        self._setup_ui()\n\n    def _setup_ui(self):\n        self.dialog.title(\"ss2md 设置\")\n        self.dialog.geometry(\"550x340\")\n        self.dialog.resizable(False, False)\n        self.dialog.transient()\n        self.dialog.grab_set()\n\n        self.dialog.update_idletasks()\n        x = (self.dialog.winfo_screenwidth() - 550) // 2\n        y = (self.dialog.winfo_screenheight() - 340) // 2\n        self.dialog.geometry(f\"550x340+{x}+{y}\")\n\n        main_frame = ttk.Frame(self.dialog, padding=20)\n        main_frame.pack(fill=\"both\", expand=True)\n\n        ttk.Label(main_frame, text=\"API 地址:\", font=(\"\", 10, \"bold\")).grid(\n            row=0, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.base_url_var = tk.StringVar(value=self.config.base_url)\n        ttk.Entry(main_frame, textvariable=self.base_url_var, width=55).grid(\n            row=1, column=0, columnspan=2, sticky=\"ew\", pady=(0, 15)\n        )\n\n        ttk.Label(main_frame, text=\"API Key:\", font=(\"\", 10, \"bold\")).grid(\n            row=2, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.api_key_var = tk.StringVar(value=self.config.api_key)\n        ttk.Entry(\n            main_frame,\n            textvariable=self.api_key_var,\n            show=\"*\",\n            width=55\n        ).grid(row=3, column=0, columnspan=2, sticky=\"ew\", pady=(0, 15))\n\n        ttk.Label(main_frame, text=\"模型:\", font=(\"\", 10, \"bold\")).grid(\n            row=4, column=0, sticky=\"w\", pady=(0, 5)\n        )\n        self.model_var = tk.StringVar(value=self.config.model_name)\n        model_combo = ttk.Combobox(\n            main_frame,\n            textvariable=self.model_var,\n            values=[\n                \"gemini-2.5-pro\",\n                \"gemini-2.0-flash\",\n                \"gpt-4o\",\n                \"gpt-4o-mini\",\n                \"claude-3-5-sonnet\",\n                \"claude-3-5-haiku\",\n            ],\n            width=52,\n            state=\"readonly\"\n        )\n        model_combo.grid(row=5, column=0, columnspan=2, sticky=\"ew\", pady=(0, 20))\n\n        hint_text = (\n            \"API 地址示例:\\n\"\n            \"  OpenAI 兼容: https://runapi.co/v1\\n\"\n            \"  Claude 兼容: https://runapi.co/v1/messages\\n\"\n            \"  Gemini 兼容: https://runapi.co/v1beta/models\"\n        )\n        ttk.Label(\n            main_frame,\n            text=hint_text,\n            font=(\"\", 9),\n            foreground=\"gray\",\n            justify=\"left\"\n        ).grid(row=6, column=0, columnspan=2, sticky=\"w\", pady=(0, 15))\n\n        btn_frame = ttk.Frame(main_frame)\n        btn_frame.grid(row=7, column=0, columnspan=2, sticky=\"e\")\n\n        ttk.Button(btn_frame, text=\"取消\", command=self.dialog.destroy).pack(\n            side=\"right\", padx=(10, 0)\n        )\n        ttk.Button(btn_frame, text=\"保存\", command=self._save).pack(side=\"right\")\n\n    def _save(self):\n        api_key = self.api_key_var.get().strip()\n        base_url = self.base_url_var.get().strip()\n        model = self.model_var.get().strip()\n\n        if not api_key:\n            mes